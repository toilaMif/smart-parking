{
  "expo": {
    "name": "Smart Parking Scanner",
    "slug": "smart-parking-scanner",
    "version": "1.0.0",
    "platforms": ["ios", "android"],
    "orientation": "portrait",
    "jsEngine": "jsc",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Ung dung can camera de quet ma QR gui xe."
      }
    },
    "android": {
      "permissions": ["CAMERA"],
      "package": "com.smartparking.scanner"
    }
  }
}
